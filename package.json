{
  "name": "kalamos",
  "private": true,
  "packageManager": "npm@11.10.0",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:web": "turbo dev --filter=@kalamos/web",
    "dev:compendium": "turbo dev --filter=@kalamos/compendium",
    "build:web": "turbo build --filter=@kalamos/web",
    "build:compendium": "turbo build --filter=@kalamos/compendium"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
